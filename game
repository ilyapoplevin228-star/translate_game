import sounddevice as sd
import numpy as np
import scipy.io.wavfile as wav
import speech_recognition as sr
from deep_translator import GoogleTranslator
import random
words_by_level = {
    "легко": ["кот", "собака", "яблоко", "молоко", "солнце"],
    "средне": ["банан", "школа", "друг", "окно", "жёлтый"],
    "сложно": ["технология", "университет", "информация", "произношение", "воображение"]
}
def perevod(word,text):
    translated = GoogleTranslator(source='auto', target='en').translate(word)
    if translated.lower() == text.lower():
        return 1
    else:
        return 0 

def speech(word,duration,sample_rate):

    recording = sd.rec(
    int(duration * sample_rate), # длительность записи в сэмплах
    samplerate=sample_rate,      # частота дискретизации
    channels=1,                  # 1 — это моно
    dtype="int16")               # формат аудиоданных
    sd.wait()  # ждём завершения записи

    wav.write("output.wav", sample_rate, recording)
    print("Запись завершена, теперь распознаём...")

    recognizer = sr.Recognizer()
    with sr.AudioFile("output.wav") as source:
        audio = recognizer.record(source)

    try:
        text = recognizer.recognize_google(audio, language="ru-RU")
        print("вы сказали " + text)
        return perevod(word,text)

    except sr.UnknownValueError:             # - если Google не понял речь (шум, молчание)
        print("Не удалось распознать речь.")
        return 0
    except sr.RequestError as e:             # - если нет интернета или API недоступен
        print(f"Ошибка сервиса: {e}")
        return 0
def translator(words,duration,sample_rate):
    print("Привет! вы зашли в игру : УмныйПереводчик.")
    print("Для начала вам нужно выбрать уровень сложности : легкий, средний, и сложный.")
    print("После этого мы дадим вам три слова ддля перевода на англйский.")
    print("Ваша задача : перевести какможно больше слов правильно!")
    count = 0
    level = input("Какой уровень сложности вы хотите выбрать? легко/средне/сложно : ")
    for i in range(1,4):
        word = random.choice(words[level])
        print(f"Ваше текущее слово {i} : " + word)
        print(f"Переводите! У вас всего {duration} секунд!")
        count += speech(word,duration,sample_rate)
    if count == 3:
        print("Вы всё правильно перевели! Вы большой молодец!")
    elif count == 2:
        print("Вы перевели почти всё правильно! Хороший результат!")
    else:
        print("Кажется что у вас не так хоршо получилось! Можете выбрать более лягкую сложнось!")

if __name__ == "__main__":
    translator(words_by_level,5,44100)
